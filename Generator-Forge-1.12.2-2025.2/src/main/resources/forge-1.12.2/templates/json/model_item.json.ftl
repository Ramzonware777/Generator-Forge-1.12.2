<#--
 # MCreator note: Minecraft 1.12.2 does not use the new 1.21+ item model definition format
 # (assets/<modid>/items/<id>.json), but MCreator expects this file to exist for all generators.
 #
 # We generate a minimal descriptor that points to the classic item model under models/item.
 -->
{
  "model": {
    "type": "minecraft:model",
    "model": "${modid}:item/${registryname}"
  }
}
